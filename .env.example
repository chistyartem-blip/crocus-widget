# Google Ads API - set these as GitHub Secrets or local .env values.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=8564224564
GOOGLE_ADS_LOGIN_CUSTOMER_ID=6093679393

# Governor controls.
# Keep false until GitHub Secrets are configured and one manual dry-run looks sane.
ADS_GOVERNOR_APPLY=false
ADS_GOVERNOR_MAX_DAILY_BUDGET_EUR=30
ADS_GOVERNOR_LOOKAHEAD_DAYS=14
ADS_GOVERNOR_REPORT_EVERY_HOURS=3
ADS_GOVERNOR_FORCE_TELEGRAM=false

# Altegio public proxy already hides the partner token server-side.
ALTEGIO_PROXY_BASE=https://crocus-proxy.crocusbeautystudio.workers.dev/api/proxy
ALTEGIO_LOCATION_ID=1357963

# Optional Telegram report delivery.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: lets the Telegram bot answer free-form marketing questions.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
